{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "ZiggyCreatures.Caching.Fusion": "Warning",
      "Infrastructure.Authentication": "Warning",
      "Web.Api.Endpoints": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSecretKey": "",
  "JwtIssuer": "http://localhost:5000",
  "JwtAudience": "feature_flags_api",
  "ConnectionStrings": {
    "FeatureFlagsDatabase": "Host=${DB_HOST};Port=5432;Database=feature_flags_db;Username=${DB_USER};Password=${DB_PASSWORD};",
    "FeatureFlagsCache": "${REDIS_CONNECTION_STRING}"
  },
  "DatabaseSeeding": {
    "Enabled": true,
    "CreateDefaultProject": true,
    "CreateSampleApiKeys": true,
    "CreateSampleFlags": true
  }
}