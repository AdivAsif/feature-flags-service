@page "/"
@using Contracts.Common
@using Contracts.Models
@using Contracts.Requests
@using Contracts.Responses
@using Domain
@using FeatureFlags.Client
@implements IAsyncDisposable
@rendermode InteractiveServer
@inject IFeatureFlagsClient FeatureFlagsClient
@inject IFeatureFlagsManagementClient FeatureFlagsManagementClient

<PageTitle>Feature Flags Management</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-4">Feature Flags</h1>
            <p class="lead">Manage your feature flags and test evaluation in real-time.</p>
        </div>
        <div class="col-auto d-flex align-items-center">
            <button class="btn btn-primary" @onclick="() => _showCreateForm = !_showCreateForm">
                <i class="bi bi-plus-circle"></i> @(_showCreateForm ? "Close Form" : "Create New Flag")
            </button>
            <button class="btn btn-outline-secondary ms-2" @onclick="LoadFeatureFlags">
                <i class="bi bi-refresh"></i> Refresh
            </button>
        </div>
    </div>

    @if (_editingFlag != null)
    {
        <div class="card mb-4 border-info">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Edit Feature Flag: @_editingFlag.Key</h5>
                <button type="button" class="btn-close btn-close-white" @onclick="CancelEditing"></button>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Description</label>
                        <input type="text" class="form-control" @bind="_editDescription"/>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="_editEnabled" id="editFlagEnabled">
                            <label class="form-check-label" for="editFlagEnabled">Enabled</label>
                        </div>
                    </div>
                    <div class="col-md-3 d-flex align-items-end justify-content-end">
                        <button class="btn btn-secondary me-2" @onclick="CancelEditing">Cancel</button>
                        <button class="btn btn-info text-white" @onclick="UpdateFeatureFlag">Save Changes</button>
                    </div>
                </div>

                <hr/>
                <h6>Rules (Parameters)</h6>
                <div class="row g-2 mb-3">
                    <div class="col-md-4">
                        <select class="form-select" @bind="_editRuleType">
                            @foreach (var type in Enum.GetValues<RuleType>())
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <input type="text" class="form-control" @bind="_editRuleValue"
                               placeholder="Value (e.g. 50, 'beta-users', 'user-123')"/>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-outline-primary w-100" @onclick="AddRuleToEditFlag">Add Rule</button>
                    </div>
                </div>

                @if (_editParameters.Any())
                {
                    <div class="list-group list-group-flush border rounded">
                        @foreach (var param in _editParameters)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="badge bg-info text-dark me-2">@param.RuleType</span>
                                    <span>@param.RuleValue</span>
                                </div>
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => RemoveRuleFromEditFlag(param)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (_showCreateForm)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Create New Feature Flag</h5>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label">Key</label>
                        <input type="text" class="form-control" @bind="_newFlagKey" placeholder="e.g. beta-feature"/>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Description</label>
                        <input type="text" class="form-control" @bind="_newFlagDescription"
                               placeholder="What does this flag do?"/>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="_newFlagEnabled" id="newFlagEnabled">
                            <label class="form-check-label" for="newFlagEnabled">Enabled by default</label>
                        </div>
                    </div>
                </div>

                <h6>Rules (Parameters)</h6>
                <div class="row g-2 mb-3">
                    <div class="col-md-4">
                        <select class="form-select" @bind="_newRuleType">
                            @foreach (var type in Enum.GetValues<RuleType>())
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <input type="text" class="form-control" @bind="_newRuleValue"
                               placeholder="Value (e.g. 50, 'beta-users', 'user-123')"/>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-outline-primary w-100" @onclick="AddRuleToNewFlag">Add Rule</button>
                    </div>
                </div>

                @if (_newFlagParameters.Any())
                {
                    <div class="list-group list-group-flush border rounded mb-3">
                        @foreach (var param in _newFlagParameters)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="badge bg-info text-dark me-2">@param.RuleType</span>
                                    <span>@param.RuleValue</span>
                                </div>
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => RemoveRuleFromNewFlag(param)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        }
                    </div>
                }

                <div class="d-flex justify-content-end">
                    <button class="btn btn-success" @onclick="CreateFeatureFlag"
                            disabled="@(string.IsNullOrWhiteSpace(_newFlagKey))">
                        Create Flag
                    </button>
                </div>
            </div>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Existing Flags</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>Key</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Rules</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        @if (_allFeatureFlags.Items.Any())
                        {
                            @foreach (var flag in _allFeatureFlags.Items)
                            {
                                <tr>
                                    <td><strong>@flag.Key</strong></td>
                                    <td>@flag.Description</td>
                                    <td>
                                        @if (flag.Enabled)
                                        {
                                            <span class="badge bg-success">Enabled</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Disabled</span>
                                        }
                                    </td>
                                    <td>
                                        @if (flag.Parameters != null && flag.Parameters.Any())
                                        {
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                                        type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                    @flag.Parameters.Length Rule(s)
                                                </button>
                                                <ul class="dropdown-menu p-2 shadow-sm" style="min-width: 200px;">
                                                    @foreach (var param in flag.Parameters)
                                                    {
                                                        <li class="mb-1">
                                                            <span
                                                                class="badge bg-info text-dark me-1">@param.RuleType</span>
                                                            <small class="text-muted">@param.RuleValue</small>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        }
                                        else
                                        {
                                            <small class="text-muted">No rules</small>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" @onclick="() => ToggleFlag(flag)"
                                                    title="Toggle Status">
                                                @(flag.Enabled ? "Disable" : "Enable")
                                            </button>
                                            <button class="btn btn-outline-info" @onclick="() => StartEditing(flag)"
                                                    title="Edit">
                                                Edit
                                            </button>
                                            <button class="btn btn-outline-info"
                                                    @onclick="() => SelectForEvaluation(flag)" title="Evaluate">
                                                Test
                                            </button>
                                            <button class="btn btn-outline-danger"
                                                    @onclick="() => DeleteFeatureFlag(flag.Key)" title="Delete">
                                                Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No feature flags found.</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-info">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Evaluate Flag</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Flag Key</label>
                        <select class="form-select" @bind="_evalKey">
                            <option value="">-- Select a flag --</option>
                            @foreach (var flag in _allFeatureFlags.Items)
                            {
                                <option value="@flag.Key">@flag.Key</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">User ID</label>
                        <input type="text" class="form-control" @bind="_evalUserId" placeholder="anonymous"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Groups (comma-separated)</label>
                        <input type="text" class="form-control" @bind="_evalGroups" placeholder="e.g. beta, internal"/>
                    </div>
                    <button class="btn btn-info w-100 text-white" @onclick="EvaluateFlag"
                            disabled="@(string.IsNullOrWhiteSpace(_evalKey))">
                        Evaluate Async
                    </button>

                    @if (_evaluationResult != null)
                    {
                        <div
                            class="mt-4 p-3 rounded @(_evaluationResult.Allowed ? "bg-success-subtle border-success" : "bg-secondary-subtle border-secondary") border">
                            <h6>Result:</h6>
                            <div class="d-flex align-items-center">
                                <h3 class="mb-0 me-2">@(_evaluationResult.Allowed ? "ON" : "OFF")</h3>
                                <small class="text-muted">(Reason: @_evaluationReason)</small>
                            </div>
                            <div class="mt-2 small text-muted">
                                Last evaluated: @DateTime.Now.ToLongTimeString()
                            </div>
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_message))
            {
                <div
                    class="alert mt-3 @(_messageIsError ? "alert-danger" : "alert-success") alert-dismissible fade show">
                    @_message
                    <button type="button" class="btn-close" @onclick="() => _message = null"></button>
                </div>
            }
        </div>
    </div>
</div>

@code
{
    private PagedResult<FeatureFlagResponse> _allFeatureFlags = new();

    // Create Form
    private bool _showCreateForm;
    private string _newFlagKey = "";
    private string _newFlagDescription = "";
    private bool _newFlagEnabled = true;
    private readonly List<FeatureFlagParameters> _newFlagParameters = new();
    private RuleType _newRuleType = RuleType.Percentage;
    private string _newRuleValue = "";

    // Edit Form
    private FeatureFlagResponse? _editingFlag;
    private string _editDescription = "";
    private bool _editEnabled;
    private List<FeatureFlagParameters> _editParameters = new();
    private RuleType _editRuleType = RuleType.Percentage;
    private string _editRuleValue = "";

    // Evaluation
    private string _evalKey = "";
    private string _evalUserId = "anonymous";
    private string _evalGroups = "";
    private EvaluationResponse? _evaluationResult;
    private string? _evaluationReason = "";

    // Notifications
    private string? _message;
    private bool _messageIsError;

    protected override async Task OnInitializedAsync()
    {
        await LoadFeatureFlags();
        await SetupRealTimeUpdates();
    }

    private async Task SetupRealTimeUpdates()
    {
        try
        {
            // The SDK will determine the Project ID from the API Key automatically
            await FeatureFlagsClient.StartListeningAsync();
            FeatureFlagsClient.OnFlagChanged += HandleFlagChanged;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to setup real-time updates: {ex.Message}");
        }
    }

    private async void HandleFlagChanged(string key)
    {
        await InvokeAsync(async () =>
        {
            await LoadFeatureFlags();
            if (_evalKey == key)
            {
                await EvaluateFlag();
            }

            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        FeatureFlagsClient.OnFlagChanged -= HandleFlagChanged;
    }

    private async Task LoadFeatureFlags()
    {
        try
        {
            _allFeatureFlags = await FeatureFlagsManagementClient.GetFeatureFlagsAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowMessage($"Error loading flags: {ex.Message}", true);
        }
    }

    private async Task CreateFeatureFlag()
    {
        try
        {
            var request = new CreateFeatureFlagRequest(_newFlagKey, _newFlagDescription, _newFlagEnabled, _newFlagParameters.ToArray());
            await FeatureFlagsManagementClient.CreateFeatureFlagAsync(request);

            _newFlagKey = "";
            _newFlagDescription = "";
            _newFlagParameters.Clear();
            _showCreateForm = false;

            ShowMessage("Flag created successfully!");
            await LoadFeatureFlags();
        }
        catch (Exception ex)
        {
            ShowMessage($"Error creating flag: {ex.Message}", true);
        }
    }

    private void AddRuleToNewFlag()
    {
        if (string.IsNullOrWhiteSpace(_newRuleValue)) return;
        _newFlagParameters.Add(new FeatureFlagParameters { RuleType = _newRuleType, RuleValue = _newRuleValue });
        _newRuleValue = "";
    }

    private void RemoveRuleFromNewFlag(FeatureFlagParameters param)
    {
        _newFlagParameters.Remove(param);
    }

    private void StartEditing(FeatureFlagResponse flag)
    {
        _editingFlag = flag;
        _editDescription = flag.Description;
        _editEnabled = flag.Enabled;
        _editParameters = flag.Parameters.ToList();
        _editRuleValue = "";
        StateHasChanged();
    }

    private void CancelEditing()
    {
        _editingFlag = null;
        StateHasChanged();
    }

    private void AddRuleToEditFlag()
    {
        if (string.IsNullOrWhiteSpace(_editRuleValue)) return;
        _editParameters.Add(new FeatureFlagParameters { RuleType = _editRuleType, RuleValue = _editRuleValue });
        _editRuleValue = "";
    }

    private void RemoveRuleFromEditFlag(FeatureFlagParameters param)
    {
        _editParameters.Remove(param);
    }

    private async Task UpdateFeatureFlag()
    {
        if (_editingFlag == null) return;

        try
        {
            var request = new UpdateFeatureFlagRequest(_editDescription, _editEnabled, _editParameters.ToArray());
            await FeatureFlagsManagementClient.UpdateFeatureFlagAsync(_editingFlag.Key, request);

            ShowMessage($"Flag '{_editingFlag.Key}' updated successfully!");

            if (_evalKey == _editingFlag.Key)
            {
                await EvaluateFlag();
            }

            _editingFlag = null;
            await LoadFeatureFlags();
        }
        catch (Exception ex)
        {
            ShowMessage($"Error updating flag: {ex.Message}", true);
        }
    }

    private async Task ToggleFlag(FeatureFlagResponse flag)
    {
        try
        {
            var request = new UpdateFeatureFlagRequest(flag.Description, !flag.Enabled, flag.Parameters);
            await FeatureFlagsManagementClient.UpdateFeatureFlagAsync(flag.Key, request);

            ShowMessage($"Flag '{flag.Key}' {(flag.Enabled ? "disabled" : "enabled")} successfully!");

            // If the flag we just toggled is the one currently in the evaluation box, re-evaluate it
            if (_evalKey == flag.Key)
            {
                await EvaluateFlag();
            }

            await LoadFeatureFlags();
        }
        catch (Exception ex)
        {
            ShowMessage($"Error updating flag: {ex.Message}", true);
        }
    }

    private async Task DeleteFeatureFlag(string key)
    {
        try
        {
            await FeatureFlagsManagementClient.DeleteFeatureFlagAsync(key);
            ShowMessage($"Flag '{key}' deleted successfully!");
            if (_evalKey == key)
            {
                _evalKey = "";
                ClearEvaluation();
            }

            await LoadFeatureFlags();
        }
        catch (Exception ex)
        {
            ShowMessage($"Error deleting flag: {ex.Message}", true);
        }
    }

    private void SelectForEvaluation(FeatureFlagResponse flag)
    {
        _evalKey = flag.Key;
        ClearEvaluation();
        StateHasChanged();
    }

    private async Task EvaluateFlag()
    {
        try
        {
            var groups = string.IsNullOrWhiteSpace(_evalGroups)
                ? null
                : _evalGroups.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList();

            var context = new EvaluationContext
            {
                UserId = _evalUserId,
                Groups = groups
            };
            _evaluationResult = await FeatureFlagsClient.EvaluateAsync(_evalKey, context);
            _evaluationReason = _evaluationResult.Reason;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowMessage($"Error evaluating flag: {ex.Message}", true);
        }
    }

    private void ClearEvaluation()
    {
        _evaluationResult = null;
        _evaluationReason = null;
        StateHasChanged();
    }

    private void ShowMessage(string message, bool isError = false)
    {
        _message = message;
        _messageIsError = isError;
        StateHasChanged();
    }
}
